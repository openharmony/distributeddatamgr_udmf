@!sts_inject("""

export class UnifiedData {
  unifiedDataInner: UnifiedDataInner;
  getInner(): long {
    return this.unifiedDataInner.getInner();
  }
  constructor() {
    this.unifiedDataInner = createUnifiedData();
  }
  constructor(inner: UnifiedDataInner) {
    this.unifiedDataInner = inner;
  }
  constructor(unifiedRecord: UnifiedRecord) {
    if (unifiedRecord instanceof Folder) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Folder).folderInner);
    } else if (unifiedRecord instanceof Audio) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Audio).audioInner);
    } else if (unifiedRecord instanceof Video) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Video).videoInner);
    } else if (unifiedRecord instanceof Image) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Image).imageInner);
    } else if (unifiedRecord instanceof PlainText) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as PlainText).plainTextInner);
    } else if (unifiedRecord instanceof HTML) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as HTML).htmlInner);
    } else if (unifiedRecord instanceof Hyperlink) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Hyperlink).hyperlinkInner);
    } else if (unifiedRecord instanceof SystemDefinedForm) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as SystemDefinedForm).systemDefinedFormInner);
    } else if (unifiedRecord instanceof SystemDefinedAppItem) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as SystemDefinedAppItem).systemDefinedAppItemInner);
    } else if (unifiedRecord instanceof SystemDefinedPixelMap) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as SystemDefinedPixelMap).systemDefinedPixelMapInner);
    } else if (unifiedRecord instanceof Text) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as Text).textInner);
    } else if (unifiedRecord instanceof File) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as File).fileInner);
    } else if (unifiedRecord instanceof SystemDefinedRecord) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as SystemDefinedRecord).systemDefinedRecordInner);
    } else if (unifiedRecord instanceof ApplicationDefinedRecord) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as ApplicationDefinedRecord).applicationDefinedRecordInner);
    } else if (unifiedRecord instanceof UnifiedRecord) {
      this.unifiedDataInner = createUnifiedDataWithParams((unifiedRecord as UnifiedRecord).unifiedRecordInner);
    }
  }
  addRecord(unifiedRecord: UnifiedRecord) {
    if (unifiedRecord instanceof Folder) {
      this.unifiedDataInner.addRecord((unifiedRecord as Folder).folderInner);
    } else if (unifiedRecord instanceof Audio) {
      this.unifiedDataInner.addRecord((unifiedRecord as Audio).audioInner);
    } else if (unifiedRecord instanceof Video) {
      this.unifiedDataInner.addRecord((unifiedRecord as Video).videoInner);
    } else if (unifiedRecord instanceof Image) {
      this.unifiedDataInner.addRecord((unifiedRecord as Image).imageInner);
    } else if (unifiedRecord instanceof PlainText) {
      this.unifiedDataInner.addRecord((unifiedRecord as PlainText).plainTextInner);
    } else if (unifiedRecord instanceof HTML) {
      this.unifiedDataInner.addRecord((unifiedRecord as HTML).htmlInner);
    } else if (unifiedRecord instanceof Hyperlink) {
      this.unifiedDataInner.addRecord((unifiedRecord as Hyperlink).hyperlinkInner);
    } else if (unifiedRecord instanceof SystemDefinedForm) {
      this.unifiedDataInner.addRecord((unifiedRecord as SystemDefinedForm).systemDefinedFormInner);
    } else if (unifiedRecord instanceof SystemDefinedAppItem) {
      this.unifiedDataInner.addRecord((unifiedRecord as SystemDefinedAppItem).systemDefinedAppItemInner);
    } else if (unifiedRecord instanceof SystemDefinedPixelMap) {
      this.unifiedDataInner.addRecord((unifiedRecord as SystemDefinedPixelMap).systemDefinedPixelMapInner);
    } else if (unifiedRecord instanceof Text) {
      this.unifiedDataInner.addRecord((unifiedRecord as Text).textInner);
    } else if (unifiedRecord instanceof File) {
      this.unifiedDataInner.addRecord((unifiedRecord as File).fileInner);
    } else if (unifiedRecord instanceof SystemDefinedRecord) {
      this.unifiedDataInner.addRecord((unifiedRecord as SystemDefinedRecord).systemDefinedRecordInner);
    } else if (unifiedRecord instanceof ApplicationDefinedRecord) {
      this.unifiedDataInner.addRecord((unifiedRecord as ApplicationDefinedRecord).applicationDefinedRecordInner);
    } else if (unifiedRecord instanceof UnifiedRecord) {
      this.unifiedDataInner.addRecord((unifiedRecord as UnifiedRecord).unifiedRecordInner);
    }
  }
  getRecords(): Array<UnifiedRecord> {
    let records = this.unifiedDataInner.getRecords();
    let arr: Array<UnifiedRecord> = new Array<UnifiedRecord>();
    for (let i = 0; i < records.length; i++ ) {
      if (records[i] instanceof UnifiedRecordInner) {
        arr.push(new UnifiedRecord(records[i] as UnifiedRecordInner));
      } else if (records[i] instanceof FileInner) {
        arr.push(new File(records[i] as FileInner));
      } else if (records[i] instanceof FolderInner) {
        arr.push(new Folder(records[i] as FolderInner));
      } else if (records[i] instanceof AudioInner) {
        arr.push(new Audio(records[i] as AudioInner));
      } else if (records[i] instanceof VideoInner) {
        arr.push(new Video(records[i] as VideoInner));
      } else if (records[i] instanceof ImageInner) {
        arr.push(new Image(records[i] as ImageInner));
      } else if (records[i] instanceof TextInner) {
        arr.push(new Text(records[i] as TextInner));
      } else if (records[i] instanceof PlainTextInner) {
        arr.push(new PlainText(records[i] as PlainTextInner));
      } else if (records[i] instanceof HTMLInner) {
        arr.push(new HTML(records[i] as HTMLInner));
      } else if (records[i] instanceof HyperlinkInner) {
        arr.push(new Hyperlink(records[i] as HyperlinkInner));
      } else if (records[i] instanceof SystemDefinedRecordInner) {
        arr.push(new SystemDefinedRecord(records[i] as SystemDefinedRecordInner));
      } else if (records[i] instanceof SystemDefinedFormInner) {
        arr.push(new SystemDefinedForm(records[i] as SystemDefinedFormInner));
      } else if (records[i] instanceof SystemDefinedAppItemInner) {
        arr.push(new SystemDefinedAppItem(records[i] as SystemDefinedAppItemInner));
      } else if (records[i] instanceof SystemDefinedPixelMapInner) {
        arr.push(new SystemDefinedPixelMap(records[i] as SystemDefinedPixelMapInner));
      } else if (records[i] instanceof ApplicationDefinedRecordInner) {
        arr.push(new ApplicationDefinedRecord(records[i] as ApplicationDefinedRecordInner));
      }
    }
    return arr;
  }
  hasType(type: string): boolean {
    return this.unifiedDataInner.hasType(type);
  }
  getTypes(): Array<string> {
    return this.unifiedDataInner.getTypes();
  }
  get properties(): UnifiedDataProperties {
    return this.unifiedDataInner.properties;
  }
  set properties(properties: UnifiedDataProperties) {
    this.unifiedDataInner.properties = properties;
  }
}

export class UnifiedRecord {
  unifiedRecordInner: UnifiedRecordInner;
  constructor() {
    this.unifiedRecordInner = createUnifiedRecord();
  }
  constructor(inner: UnifiedRecordInner) {
    this.unifiedRecordInner = inner;
  }

  constructor(type: string, value: ValueType) {
    this.unifiedRecordInner = createUnifiedRecordWithParams(type, value);
