async function delayedDataLoadHandlerFuncAsync(
    handler: DelayedDataLoadHandler, info: DataLoadInfo): Promise<UnifiedData | null> {
    return handler(info);
}

function delayedDataLoadHandlerFunc(handler: DelayedDataLoadHandler, info: DataLoadInfo): UnifiedData | null {
    let ret = waitForCompletion(async () => {
      return await delayedDataLoadHandlerFuncAsync(handler, info);
    })
    return ret;
}
